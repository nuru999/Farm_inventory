# Flask Configuration
FLASK_ENV=development
FLASK_APP=app-improved.py
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Database Configuration
# For development (SQLite):
# DEV_DATABASE_URL=sqlite:///farm_dev.db

# For production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/farm_inventory_db
# Example with environment-specific setup:
# DATABASE_URL=postgresql://postgres:mypassword@db.example.com:5432/farm_prod

# Secret Key (change in production!)
SECRET_KEY=your-secret-key-here-change-in-production

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Logging
LOG_LEVEL=INFO
